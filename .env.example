# LLM 配置
LAS_LLM_PROVIDER=openai
LAS_LLM_MODEL=gpt-4o
LAS_LLM_API_KEY=sk-your-key-here
LAS_LLM_BASE_URL=https://api.openai.com/v1
LAS_LLM_MAX_TOKENS=32000
LAS_LLM_TEMPERATURE=0.4

# 安全
LAS_SECRET_KEY=change-me-to-a-random-string
LAS_JWT_EXPIRE_HOURS=24

# 数据库
LAS_DB_PATH=data/las.db

# 提示词版本（v2 = json-mode 自包含文件推荐，v1 = 原始 MD 裁剪模式）
LAS_PROMPT_VERSION=v2

# 开发模式（设为 true 时跳过认证）
LAS_DEV=false

# CORS（逗号分隔的允许来源，生产环境必须设置）
LAS_CORS_ORIGINS=http://localhost:8000
