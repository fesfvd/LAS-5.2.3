# ── LLM 配置 ──
# 服务商: deepseek (推荐) / openai (兼容)
# 生成 API Key: https://platform.deepseek.com/api_keys
LAS_LLM_PROVIDER=openai
LAS_LLM_MODEL=deepseek-v4-flash
LAS_LLM_API_KEY=sk-your-key-here
LAS_LLM_BASE_URL=https://api.deepseek.com/v1
LAS_LLM_MAX_TOKENS=32000
LAS_LLM_TEMPERATURE=0.4

# ── 邮件（163 / QQ / 企业邮箱 SMTP）──
LAS_SMTP_HOST=smtp.163.com
LAS_SMTP_PORT=465
LAS_SMTP_USER=your-email@163.com
LAS_SMTP_PASS=your-smtp-auth-code
LAS_SMTP_FROM=your-email@163.com

# ── 安全 ──
# 生产环境必须用随机字符串: python -c "import secrets; print(secrets.token_urlsafe(32))"
LAS_SECRET_KEY=change-me-to-a-random-string
LAS_JWT_EXPIRE_HOURS=24

# ── 数据库 ──
LAS_DB_PATH=data/las.db

# ── 提示词版本 ──
# v2 = JSON 模式（当前推荐） / v1 = 原始 MD 模式
LAS_PROMPT_VERSION=v2

# ── 开发模式 ──
# true = 跳过认证 + 通配 CORS（仅本地开发）
# false = 生产模式（需要 JWT + 限制 CORS）
LAS_DEV=false

# ── CORS ──
# 生产环境: 填写你的域名，多个用逗号分隔
# 示例: https://your-domain.com,https://www.your-domain.com
LAS_CORS_ORIGINS=http://localhost:8000
